{
	"name": "n8n-nodes-pdf-lib-tool",
	"version": "0.1.10",
	"description": "Edit PDF files in n8n workflows using pdf-lib (merge, extract pages, rotate pages).",
	"license": "MIT",
	"homepage": "https://github.com/anjuba1017/pdf-lib-n8n",
	"keywords": [
		"n8n-community-node-package",
		"n8n",
		"pdf",
		"pdf-lib"
	],
	"author": {
		"name": "julian barrios",
		"email": "julian.barrios@globalfy.com"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/anjuba1017/pdf-lib-n8n.git"
	},
	"scripts": {
		"build": "n8n-node build",
		"build:watch": "tsc --watch",
		"dev": "n8n-node dev",
		"lint": "n8n-node lint",
		"lint:fix": "n8n-node lint --fix",
		"release": "n8n-node release",
		"prepublishOnly": "n8n-node prerelease"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"strict": false,
		"credentials": [],
		"nodes": [
			"dist/nodes/PdfLib/PdfLib.node.js"
		]
	},
	"devDependencies": {
		"@n8n/node-cli": "*",
		"eslint": "9.32.0",
		"prettier": "3.6.2",
		"release-it": "^19.0.4",
		"typescript": "5.9.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	},
	"dependencies": {
		"pdf-lib": "^1.17.1"
	}
}
